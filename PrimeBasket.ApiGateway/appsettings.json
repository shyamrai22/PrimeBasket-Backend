{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Jwt": {
    "Key": "my_very_secure_and_long_jwt_secret_key_1234567890!@#",
    "Issuer": "PrimeBasket",
    "Audience": "PrimeBasketUsers"
  },

  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "product-route": {
        "ClusterId": "product-cluster",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-api": {
            "Address": "http://localhost:5010/"
          }
        }
      },
      "product-cluster": {
        "Destinations": {
          "product-api": {
            "Address": "http://localhost:5209/"
          }
        }
      }
    }
  }
}