{
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "product-route": {
        "ClusterId": "product-cluster",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        }
      },
      "cart-route": {
        "ClusterId": "cart-cluster",
        "Match": {
          "Path": "/api/cart/{**catch-all}"
        }
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      }
    },

    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-api": {
            "Address": "http://localhost:5010/"
          }
        }
      },

      "product-cluster": {
        "Destinations": {
          "product-api": {
            "Address": "http://localhost:5209/"
          }
        }
      },

      "cart-cluster": {
        "Destinations": {
          "cart-api": {
            "Address": "http://localhost:5012/"
          }
        }
      },

      "order-cluster": {
        "Destinations": {
          "order-api": {
            "Address": "http://localhost:5157/"
          }
        }
      }
    }
  },

  "Jwt": {
    "Key": "my_very_secure_and_long_jwt_secret_key_1234567890!@#",
    "Issuer": "PrimeBasket",
    "Audience": "PrimeBasketUsers"
  }
}